amends "package://github.com/jdx/hk/releases/download/v1.21.0/hk@1.21.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.21.0/hk@1.21.0#/Builtins.pkl"

local linters = new Mapping<String, Step> {
    // uses builtin prettier linter config
    ["prettier"] = Builtins.prettier

    // define a custom linter
    ["pkl"] {
        glob = "*.pkl"
        check = "pkl eval {{files}} >/dev/null"
    }
}

hooks {
    ["pre-commit"] {
        fix = true    // automatically modify files with available linter fixes
        stash = "git" // stashes unstaged changes while running fix steps
    }
    // instead of pre-commit, you can instead define pre-push hooks
    ["pre-push"] {
        steps = linters
    }
    // validate conventional commits (https://www.conventionalcommits.org/en/v1.0.0/)
    ["commit-msg"] {
        steps {
            ["conventional-commit"] {
                check = #"head -1 {{commit_msg_file}} | grep -qE '^(fix|feat|chore|docs|style|refactor|perf|test|build|ci|revert)(\(.+\))?!?: .+' || { echo 'Commit message must follow Conventional Commits: <type>[scope][!]: <description>'; exit 1; }"#
            }
        }
    }
    // "fix" and "check" are special steps for `hk fix` and `hk check` commands
    ["fix"] {
        fix = true
        steps = linters
    }
    ["check"] {
        steps = linters
    }
}
