{
  "permissions": {
    "allow": [
      "Bash(mise tasks)",
      "Bash(mise tasks:*)",
      "Bash(mise run:*)",
      "Bash(cargo *:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git ls-files:*)",
      "Bash(git rev-parse:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(gron:*)",
      "Bash(htmlq:*)",
      "Bash(xsv:*)",
      "Bash(fq:*)",
      "Bash(eza:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(prek run:*)"
    ],
    "deny": [
      "Bash(cog bump:*)",
      "Bash(git push:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(cargo publish:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)"
    ],
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "ponytail@ponytail": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "huggingface-skills@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "gitlab@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "remember@claude-plugins-official": true,
    "terraform@claude-plugins-official": true,
    "datadog@claude-plugins-official": true,
    "aikido@claude-plugins-official": true,
    "auth0@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
