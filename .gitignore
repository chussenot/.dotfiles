# Ignore all files that start with a dot, except for tracked dotfiles
.*
!.gitignore
!.gitignore_global
!.markdownlint.json

# Track Claude Code project-level subagents, skills, hooks, shared settings,
# and CLAUDE.md. These overrides also defeat the global ~/.gitignore rules of
# `.claude/*` and `CLAUDE.md`.
!.claude/
!.claude/agents/
!.claude/agents/*.md
!.claude/skills/
!.claude/skills/**
!.claude/hooks/
!.claude/hooks/*.sh
!.claude/settings.json
.claude/settings.local.json
!CLAUDE.md

specs/*
.claude/worktrees

# Python bytecode (e.g. tmux claude-sessions picker)
__pycache__/
*.pyc
